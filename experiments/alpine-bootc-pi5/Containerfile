FROM scratch AS ctx

COPY build_files /build_files
COPY system_files /system_files

ARG BOOTC_BIN_IMAGE=ghcr.io/bupd/homelab/bootc-bin-alpine-arm64:latest
FROM --platform=$TARGETPLATFORM ${BOOTC_BIN_IMAGE} AS bootc-bin

FROM --platform=$TARGETPLATFORM alpine:3.23

COPY --from=ctx /build_files /build_files
COPY --from=ctx /system_files /
COPY --from=bootc-bin /usr/bin/bootc /usr/bin/bootc

RUN chmod +x /build_files/*.sh /etc/init.d/k3s /etc/init.d/cloudflared && \
    /build_files/00-install.sh && \
    /build_files/10-bootc-rootfs.sh && \
    /build_files/20-enable-services.sh && \
    /build_files/90-cleanup.sh

LABEL containers.bootc=1
LABEL ostree.bootable=1
LABEL org.opencontainers.image.title="alpine-bootc-pi5"
LABEL org.opencontainers.image.description="Experimental Alpine Linux bootc image for Raspberry Pi 5"

RUN bootc container lint || true

CMD ["/sbin/init"]
