FROM --platform=$TARGETPLATFORM alpine:3.23 AS builder

ARG BOOTC_VERSION

RUN test -n "$BOOTC_VERSION" && \
    apk add --no-cache \
      build-base \
      cargo \
      curl \
      libarchive-dev \
      openssl-dev \
      ostree-dev \
      pkgconf \
      rust \
      tar \
      zstd

WORKDIR /src/bootc
RUN curl -fsSL -o /tmp/bootc.tar.zstd "https://github.com/bootc-dev/bootc/releases/download/v${BOOTC_VERSION}/bootc-${BOOTC_VERSION}.tar.zstd" && \
    tar --zstd -xf /tmp/bootc.tar.zstd --strip-components=1 -C /src/bootc && \
    sed -i \
      -e 's/libc::OVERLAYFS_SUPER_MAGIC/(libc::OVERLAYFS_SUPER_MAGIC as u64)/g' \
      -e 's/libc::MSDOS_SUPER_MAGIC/(libc::MSDOS_SUPER_MAGIC as u64)/g' \
      -e 's/libc::TMPFS_MAGIC/(libc::TMPFS_MAGIC as u64)/g' \
      crates/lib/src/generator.rs crates/lib/src/install.rs && \
    cargo build --locked --release --bin bootc && \
    install -Dm0755 target/release/bootc /output/usr/bin/bootc

FROM --platform=$TARGETPLATFORM alpine:3.23

ARG BOOTC_VERSION

RUN apk add --no-cache \
      libarchive \
      openssl \
      ostree

COPY --from=builder /output/usr/bin/bootc /usr/bin/bootc

LABEL org.opencontainers.image.title="bootc-bin-alpine-arm64"
LABEL org.opencontainers.image.description="bootc release binary built natively on Alpine ARM64"
LABEL org.opencontainers.image.version="${BOOTC_VERSION}"

ENTRYPOINT ["/usr/bin/bootc"]
