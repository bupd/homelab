BOOTSY_REVERSE_SSH_ENABLE=1
BOOTSY_REVERSE_SSH_HOST=
BOOTSY_REVERSE_SSH_USER=
BOOTSY_REVERSE_SSH_PORT=22
BOOTSY_REVERSE_SSH_REMOTE_BIND=127.0.0.1
BOOTSY_REVERSE_SSH_REMOTE_PORT=2222
BOOTSY_REVERSE_SSH_LOCAL_PORT=22
BOOTSY_REVERSE_SSH_STRICT_HOST_KEY=accept-new
BOOTSY_REVERSE_SSH_KEY=/boot/firmware/bootsy-reverse-ssh.key
BOOTSY_BEACON_URL=
BOOTSY_BEACON_UDP_HOST=
BOOTSY_BEACON_UDP_PORT=5514
BOOTSY_BEACON_TIMEOUT=5
