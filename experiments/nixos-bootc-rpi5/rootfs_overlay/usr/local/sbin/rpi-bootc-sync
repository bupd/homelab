#!/bin/sh
set -eu

root="/"
boot="${RPI_BOOTC_BOOT:-/boot/firmware}"
entry=""
kernel_name="${RPI_BOOTC_KERNEL_NAME:-bootc-vmlinuz}"
initramfs_name="${RPI_BOOTC_INITRAMFS_NAME:-bootc-initramfs.img}"
extra_cmdline="${RPI_BOOTC_EXTRA_CMDLINE:-}"
dry_run=0

usage() {
    cat <<'EOF'
Usage:
  rpi-bootc-sync [--root ROOT] [--boot BOOT] [--entry BLS]
                 [--kernel-name NAME] [--initramfs-name NAME] [--dry-run]

Copies a bootc deployment's BLS-selected kernel/initramfs and Raspberry Pi
firmware files to the FAT boot partition, then writes config.txt/cmdline.txt
for Raspberry Pi firmware.

ROOT is the mounted bootc root filesystem. BOOT is the mounted Raspberry Pi FAT
boot partition. On a running system, bootc owns /boot and the Raspberry Pi FAT
partition should be mounted at /boot/firmware. The tool can also run offline
from a build/repair host.
EOF
}

log() {
    printf '%s\n' "$*" >&2
}

die() {
    log "rpi-bootc-sync: $*"
    exit 1
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --root)
            root="${2:-}"
            shift 2
            ;;
        --boot)
            boot="${2:-}"
            shift 2
            ;;
        --entry)
            entry="${2:-}"
            shift 2
            ;;
        --kernel-name)
            kernel_name="${2:-}"
            shift 2
            ;;
        --initramfs-name)
            initramfs_name="${2:-}"
            shift 2
            ;;
        --dry-run)
            dry_run=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "unknown argument: $1"
            ;;
    esac
done

[ -n "$root" ] || die "--root cannot be empty"
[ -n "$boot" ] || die "--boot cannot be empty"
[ -d "$root" ] || die "root mount not found: $root"
[ -d "$boot" ] || die "boot mount not found: $boot"

trim_slash() {
    value="$1"
    while [ "$value" != "/" ] && [ "${value%/}" != "$value" ]; do
        value="${value%/}"
    done
    printf '%s\n' "$value"
}

root="$(trim_slash "$root")"
boot="$(trim_slash "$boot")"

find_latest_bls() {
    find "$root/boot" -path '*/loader/entries/*.conf' -type f 2>/dev/null | sort | tail -n 1
}

if [ -z "$entry" ]; then
    entry="$(find_latest_bls || true)"
fi
[ -n "$entry" ] || die "no BLS entry found under $root/boot/loader/entries"
[ -f "$entry" ] || die "BLS entry not found: $entry"

bls_value() {
    key="$1"
    awk -v key="$key" '
        $1 == key {
            sub("^[^ ]+[ ]+", "")
            print
            exit
        }
    ' "$entry"
}

linux_path="$(bls_value linux)"
initrd_path="$(bls_value initrd)"
options="$(bls_value options)"

[ -n "$linux_path" ] || die "BLS entry has no linux line: $entry"
[ -n "$initrd_path" ] || die "BLS entry has no initrd line: $entry"
[ -n "$options" ] || die "BLS entry has no options line: $entry"

resolve_boot_path() {
    bls_path="$1"
    case "$bls_path" in
        /boot/*)
            candidates="$root$bls_path"
            ;;
        /*)
            candidates="$root/boot$bls_path
$root$bls_path"
            ;;
        *)
            candidates="$root/boot/$bls_path"
            ;;
    esac

    printf '%s\n' "$candidates" | while IFS= read -r candidate; do
        [ -f "$candidate" ] && {
            printf '%s\n' "$candidate"
            exit 0
        }
    done
}

kernel_src="$(resolve_boot_path "$linux_path" || true)"
initramfs_src="$(resolve_boot_path "$initrd_path" || true)"
[ -n "$kernel_src" ] || die "cannot resolve BLS linux path: $linux_path"
[ -n "$initramfs_src" ] || die "cannot resolve BLS initrd path: $initrd_path"

find_firmware_dir() {
    if [ -d "$root/usr/lib/rpi-boot" ]; then
        printf '%s\n' "$root/usr/lib/rpi-boot"
        return 0
    fi

    find "$root/ostree/deploy" -path '*/deploy/*.0/usr/lib/rpi-boot' -type d 2>/dev/null | sort | tail -n 1
}

firmware_dir="$(find_firmware_dir || true)"
[ -n "$firmware_dir" ] || die "no Raspberry Pi firmware directory found in deployment"
[ -d "$firmware_dir" ] || die "firmware directory not found: $firmware_dir"

cmdline="$options"
if [ -n "$extra_cmdline" ]; then
    cmdline="$cmdline $extra_cmdline"
fi

config_content="# Generated by rpi-bootc-sync. Put local overrides in usercfg.txt.
[all]
arm_64bit=1
enable_uart=1
kernel=$kernel_name
initramfs $initramfs_name followkernel
include usercfg.txt
"

backup_once() {
    file="$1"
    [ -f "$file" ] || return 0
    [ -f "$file.previous" ] && return 0
    cp "$file" "$file.previous"
}

write_atomic() {
    file="$1"
    content="$2"
    tmp="$file.tmp.$$"
    printf '%s' "$content" > "$tmp"
    mv "$tmp" "$file"
}

log "BLS entry: ${entry#$root/}"
log "kernel: $linux_path -> $kernel_name"
log "initramfs: $initrd_path -> $initramfs_name"
log "firmware: ${firmware_dir#$root/}"

if [ "$dry_run" = 1 ]; then
    log "dry run: would copy firmware, kernel, initramfs, config.txt, and cmdline.txt"
    printf '%s\n' "$cmdline"
    exit 0
fi

mkdir -p "$boot"

find "$firmware_dir" -mindepth 1 -maxdepth 1 ! -name boot -exec cp -R -L {} "$boot"/ \;
cp "$kernel_src" "$boot/$kernel_name"
cp "$initramfs_src" "$boot/$initramfs_name"

backup_once "$boot/config.txt"
backup_once "$boot/cmdline.txt"

write_atomic "$boot/config.txt" "$config_content"
write_atomic "$boot/cmdline.txt" "$cmdline
"
touch "$boot/usercfg.txt"
sync

log "updated Raspberry Pi boot partition: $boot"
